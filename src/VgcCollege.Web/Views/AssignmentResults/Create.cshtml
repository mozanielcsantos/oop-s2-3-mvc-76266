@model VgcCollege.Web.Entities.AssignmentResult

@{
    ViewData["Title"] = "Create Assignment Result";
}

<h1 class="mb-4">Create Assignment Result</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="AssignmentId" class="form-label">Assignment</label>
                <select asp-for="AssignmentId" asp-items="ViewBag.Assignments" class="form-control">
                    <option value="">Select assignment</option>
                </select>
                <span asp-validation-for="AssignmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label">Student</label>
                <select asp-for="StudentProfileId" asp-items="ViewBag.Students" class="form-control">
                    <option value="">Select student</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Feedback" class="form-label"></label>
                <textarea asp-for="Feedback" class="form-control"></textarea>
                <span asp-validation-for="Feedback" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
