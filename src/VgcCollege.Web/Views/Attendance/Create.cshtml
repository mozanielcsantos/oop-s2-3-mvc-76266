@model VgcCollege.Web.Entities.AttendanceRecord

@{
    ViewData["Title"] = "Create Attendance Record";
    var enrolment = ViewBag.Enrolment as VgcCollege.Web.Entities.CourseEnrolment;
}

<h1 class="mb-4">Create Attendance Record</h1>

@if (enrolment != null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="mb-2">@enrolment.StudentProfile?.Name</h4>
            <p class="mb-1"><strong>Course:</strong> @enrolment.Course?.Name</p>
            <p class="mb-1"><strong>Branch:</strong> @enrolment.Course?.Branch?.Name</p>
            <p class="mb-0"><strong>Status:</strong> @enrolment.Status</p>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input asp-for="CourseEnrolmentId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="SessionDate" class="form-label"></label>
                <input asp-for="SessionDate" type="date" class="form-control" />
                <span asp-validation-for="SessionDate" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Present" class="form-check-input" />
                <label asp-for="Present" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" asp-route-enrolmentId="@Model.CourseEnrolmentId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
