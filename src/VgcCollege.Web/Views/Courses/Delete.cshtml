@model VgcCollege.Web.Entities.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h1 class="mb-4">Delete Course</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <p>Are you sure you want to delete this course?</p>

        <dl class="row">
            <dt class="col-sm-2">Course</dt>
            <dd class="col-sm-10">@Model.Name</dd>

            <dt class="col-sm-2">Branch</dt>
            <dd class="col-sm-10">@Model.Branch?.Name</dd>

            <dt class="col-sm-2">Start Date</dt>
            <dd class="col-sm-10">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-2">End Date</dt>
            <dd class="col-sm-10">@Model.EndDate.ToString("dd/MM/yyyy")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
