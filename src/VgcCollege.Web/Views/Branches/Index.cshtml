@model IEnumerable<VgcCollege.Web.Entities.Branch>

@{
    ViewData["Title"] = "Branches";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Branches</h1>
    <a asp-action="Create" class="btn btn-primary">Add Branch</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="mb-0">No branches found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Address</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var branch in Model)
                    {
                        <tr>
                            <td>@branch.Name</td>
                            <td>@branch.Address</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@branch.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@branch.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
