@model VgcCollege.Web.Entities.CourseEnrolment

@{
    ViewData["Title"] = "Delete Enrolment";
}

<h1 class="mb-4">Delete Enrolment</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <p>Are you sure you want to delete this enrolment?</p>

        <dl class="row">
            <dt class="col-sm-2">Student</dt>
            <dd class="col-sm-10">@Model.StudentProfile?.Name</dd>

            <dt class="col-sm-2">Course</dt>
            <dd class="col-sm-10">@Model.Course?.Name</dd>

            <dt class="col-sm-2">Branch</dt>
            <dd class="col-sm-10">@Model.Course?.Branch?.Name</dd>

            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@Model.Status</dd>

            <dt class="col-sm-2">Enrol Date</dt>
            <dd class="col-sm-10">@Model.EnrolDate.ToString("dd/MM/yyyy")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
