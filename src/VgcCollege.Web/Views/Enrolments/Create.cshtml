@model VgcCollege.Web.Entities.CourseEnrolment

@{
    ViewData["Title"] = "Create Enrolment";
}

<h1 class="mb-4">Create Enrolment</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label">Student</label>
                <select asp-for="StudentProfileId" asp-items="ViewBag.Students" class="form-select">
                    <option value="">Select a student</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CourseId" class="form-label">Course</label>
                <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select">
                    <option value="">Select a course</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EnrolDate" class="form-label"></label>
                <input asp-for="EnrolDate" type="date" class="form-control" />
                <span asp-validation-for="EnrolDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
